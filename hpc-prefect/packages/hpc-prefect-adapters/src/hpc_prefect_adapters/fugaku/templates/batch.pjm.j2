#!/bin/sh
# ===== Fugaku (PJM) job script generated by Prefect =====
#PJM -L "rscgrp={{ resource_group }}"
{% if elapse_time %}
#PJM -L "elapse={{ elapse_time }}"
{% endif %}
{% if num_nodes %}
#PJM -L "node={{ num_nodes }}"
{% endif %}
{% if group_name %}
#PJM -g {{ group_name }}                      
{% endif %}

{% if mpi_options_for_pjm %}
{% for option in mpi_options_for_pjm %}
#PJM --mpi "{{ option }}"
{% endfor %}
{% endif %}

{% if gfscache %}
#PJM -x PJM_LLIO_GFSCACHE={{ gfscache }}
{% endif %}

#PJM -o {{ stdout_path }}
#PJM -e {{ stderr_path }}
#PJM -S
#PJM --spath {{ stat_path }}
#PJM --name {{ job_name }}

{% if environments %}
{% for k, v in environments.items() %}
export {{ k }}="{{ v }}"
{% endfor %}
{% endif %}

{% if spack_modules %}
. /vol0004/apps/oss/spack/share/spack/setup-env.sh
{% for module in spack_modules %}
spack load {{ module }}
{% endfor %}
{% endif %}

{% if launcher == "single" %}
{% set base_cmd = executable %}
{% elif launcher == "mpiexec" %}
{% if mpi_options %}
{% set base_cmd = "mpiexec " ~ (' '.join(mpi_options)) ~ " " ~ executable %}
{% else %}
{% set base_cmd = "mpiexec " ~ executable %}
{% endif %}
{% else %}
{% if mpi_options %}
{% set base_cmd = launcher ~ " " ~ (' '.join(mpi_options)) ~ " " ~ executable %}
{% else %}
{% set base_cmd = launcher ~ " " ~ executable %}
{% endif %}
{% endif %}

{% if arguments %}
{{ base_cmd }} {{ arguments | join(' ') }}
{% else %}
{{ base_cmd }}
{% endif %}